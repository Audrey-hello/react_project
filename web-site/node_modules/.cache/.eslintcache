te/src/components/components/GoToTop.js":"25"},{"size":573,"mtime":1628284053323,"results":"26","hashOfConfig":"27"},{"size":362,"mtime":1626596782611,"results":"28","hashOfConfig":"27"},{"size":1725,"mtime":1629799844846,"results":"29","hashOfConfig":"27"},{"size":3909,"mtime":1632422749029,"results":"30","hashOfConfig":"27"},{"size":368,"mtime":1629631295597,"results":"31","hashOfConfig":"27"},{"size":374,"mtime":1632508631160,"results":"32","hashOfConfig":"27"},{"size":1293,"mtime":1632510657124,"results":"33","hashOfConfig":"27"},{"size":4401,"mtime":1630664578338,"results":"34","hashOfConfig":"27"},{"size":2316,"mtime":1629973530884,"results":"35","hashOfConfig":"27"},{"size":441,"mtime":1629053077182,"results":"36","hashOfConfig":"27"},{"size":660,"mtime":1632422052569,"results":"37","hashOfConfig":"27"},{"size":3224,"mtime":1629996834941,"results":"38","hashOfConfig":"27"},{"size":2405,"mtime":1629996839014,"results":"39","hashOfConfig":"27"},{"size":7105,"mtime":1632571799562,"results":"40","hashOfConfig":"27"},{"size":4373,"mtime":1632507767774,"results":"41","hashOfConfig":"27"},{"size":3443,"mtime":1632420995707,"results":"42","hashOfConfig":"27"},{"size":2304,"mtime":1630511297721,"results":"43","hashOfConfig":"27"},{"size":2917,"mtime":1629996887372,"results":"44","hashOfConfig":"27"},{"size":5404,"mtime":1630664044109,"results":"45","hashOfConfig":"27"},{"size":2418,"mtime":1629721050198,"results":"46","hashOfConfig":"27"},{"size":252,"mtime":1628341120513,"results":"47","hashOfConfig":"27"},{"size":332,"mtime":1629204111050,"results":"48","hashOfConfig":"27"},{"size":524,"mtime":1629799404644,"results":"49","hashOfConfig":"27"},{"size":359,"mtime":1629628609212,"results":"50","hashOfConfig":"27"},{"size":280,"mtime":1629752232024,"results":"51","hashOfConfig":"27"},{"filePath":"52","messages":"53","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},"ylw4d0",{"filePath":"55","messages":"56","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"57","messages":"58","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"59","messages":"60","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"61","messages":"62","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"63","messages":"64","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"65","messages":"66","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"67","messages":"68","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"69","messages":"70","errorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"71","usedDeprecatedRules":"54"},{"filePath":"72","messages":"73","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"74","usedDeprecatedRules":"54"},{"filePath":"75","messages":"76","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"77","messages":"78","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":1,"source":"79","usedDeprecatedRules":"54"},{"filePath":"80","messages":"81","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":1,"source":"82","usedDeprecatedRules":"54"},{"filePath":"83","messages":"84","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"85","messages":"86","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":1,"source":"87","usedDeprecatedRules":"54"},{"filePath":"88","messages":"89","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"90","messages":"91","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"92","messages":"93","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"94","messages":"95","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"96","messages":"97","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"98","usedDeprecatedRules":"54"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"103","messages":"104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"105","messages":"106","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"107","messages":"108","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},"/Users/admin/code/Audrey-hello/web-site/src/index.js",[],["109","110"],"/Users/admin/code/Audrey-hello/web-site/src/reportWebVitals.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/App.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Contact.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/pages/Home.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Banner.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Profile.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Cards.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Footer.js",["111","112","113","114","115"],"/* eslint-disable jsx-a11y/alt-text */\nimport { Link } from 'react-router-dom';\nimport './Footer.css';\nimport instagram from './instagram.svg';\nimport facebook from './facebook.svg';\nimport mail from './mail.svg';\nimport pinterest from './pinterest.svg';\nimport tiktok from './tiktok.svg';\n\n\nfunction Footer() {\n  return (\n    <div className='footer-container'>\n      <div className=\"logo-footer\">\n        <h1 className=\"title-logo\">Résonance </h1>\n      </div>\n      <div className=\"footer-links\">\n        <h2 className=\"title-footer\"> Me suivre </h2>\n        <div className=\"social-media-footer\">\n          <a href=\"https://www.instagram.com/ana.resonance/\"><i><img src={instagram} className=\"social-logo\" alt=\"image du logo insta\" /></i></a>\n          <a href=\"https://vm.tiktok.com/ZMRMAQFm9/\" ><i><img src={tiktok} className=\"social-logo\" alt=\"image du logo tiktok\" /></i></a>\n          <a href=\"https://www.facebook.com/resonance.anahata\" ><i><img src={facebook} className=\"social-logo\" alt=\"image du logo facebook\" /></i></a>\n          <a href=\"https://www.pinterest.fr/anahataresonance/_created/\" ><i><img src={pinterest} className=\"social-logo-pint\" alt=\"image du logo facebook\" /></i></a>\n        </div>\n      </div>\n      <div className=\"contact-content\">\n        <div className=\"contacter\">\n          <h2 className=\"title-footer\" id='footer'>Me contacter</h2>\n          <div className=\"social-logo-mail\" >\n            <Link to={'/Contact'} >\n            <img src={mail} className=\"social-logo-mail\" alt=\"image du logo mail\" />\n            </Link>\n          </div>\n        </div>\n      </div>\n      <div className=\"mentions-légales\">\n        <h2 className=\"title-mention\" > Conditions générales du site </h2>\n        <div className=\"block-lien-mention\">\n          <a href=\"https://docs.google.com/document/d/1d9N3qxisZQ_xxm1bSfb7_k7EeZe5O4-B4vTLXVc2oCk/edit?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Mentions légales</a>\n          <a href=\"https://drive.google.com/file/d/148ZLMYZs71JNm87HV19-L-t_PTVNaJMc/view?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Politique de confidentialité\n          </a>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Banner2.js",["116"],"import React from 'react';\nimport './Banner.css';\n\nfunction Banner2() {\n  return (\n    <div className='banner-container2'>\n      <div className=\"image-banner2\" >\n        <img src=\"https://images.unsplash.com/photo-1517363898874-737b62a7db91?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1558&q=80\" alt=\"image unsplash d'une femme méditant\"/>\n      </div>\n    </div>\n  )\n};\n\nexport default Banner2;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Button.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Yoga.js",["117"],"/* eslint-disable react/style-prop-object */\nimport React from 'react';\nimport \"./Yoga.css\";\nimport ReactPlayer from 'react-player';\nimport picture6 from './picture6.JPG';\nimport Topbar from './Topbar';\nimport Footer from './Footer';\nimport GoToTop from './GoToTop';\n\n\n\n\n\nexport default function Yoga() {\n  return (\n    <div className='yoga-container' >\n      <GoToTop />\n      <div className=\"yoga-banner\" id='yoga'>\n         <Topbar />\n        <ReactPlayer\n          url='yoga2.mp4'\n          className=\"video\"\n          width=\"100%\"\n          height=\"100%\"\n          object-fit=\"cover\"\n          muted={true}\n          playing={true}\n          loop={true}\n          controls={false}\n          allowfullscreen={true}/>\n      </div>\n      <div className=\"content-yoga\">\n        <div className='profile-content-yoga'>\n          <h2>  Connexion au corps et à l'esprit  </h2> <br />\n\n          <p>Le Vinyasa yoga est une pratique dynamique issue de l'Ashtanga enchaînant les asanas avec créativité et fluidité. Cela permet de relâcher les tensions, se réancrer et se reconnecter à son corps. Cela contribue ainsi à une meilleure santé mentale, à la gestion de ses émotions, et à apprendre à aimer son corps. <strong>C'est donc un véritable outil aidant la confiance en soi ! </strong></p><br />\n\n          <h3> Les valeurs que je divulgue par le yoga </h3><br />\n\n          <p> Le yoga n'est pas juste un outil bien-être, c'est une philosophie indienne qui existe depuis des siècles. Si les postures font référence à l'aspect physique lié au corps, à la discipline, à la respiration il y a aussi tout un aspect plus spirituel. <strong>Les valeurs de bienveillance, de respect, de compassion, de non-jugement sont tout aussi importantes pour moi dans cette pratique. </strong> </p> <br />\n          <p> De même, le yoga est ouvert à tout le monde quelque soit ta morphologie, niveau...Aussi je trouve important de respecter les racines de cette pratique et éviter l'appropriation culturelle en se centrant uniquement sur l'aspect physique. <strong> Le yoga est représenté dans la diversité ! </strong>De même, il n' y a pas de compétition en yoga, <strong> tu y vas à ton rythme </strong>en fonction de ta pratique.</p>\n\n\n          <li>Je propose des cours collectif de débutant.e à intermédiaire.</li><br />\n          <li>Des cours individuels sont aussi proposés dans une optique d'accompagnement.</li><br />\n          <li>Pour bénéficier de plusieurs outils complémentaires au yoga, rejoignez le programme \"Metta\" !</li><br />\n\n          <h3> Ressources </h3><br />\n\n          <p> -  Susanna Barkataki  et son livre \"Embrace Yoga's Roots: Courageous Ways to Deepen Your Yoga Practice\".</p>\n          <p> - Le compte yogaisdeadpodcast. </p>\n          <p> - Henikapetal avec School of Sensual Arts.</p>\n\n          <a href=\"https://www.instagram.com/ana.resonance/\" target=\"_blank\" rel=\"noopener\"><button  className=\"btn btn--follow\">\n            ▻▻ Suivre les prochaines sessions\n          </button></a>\n\n        </div>\n        <div>\n          <img className='image-profile-yoga2' src={picture6} alt='Mon profile' />\n        </div>\n      </div>\n      <Footer />\n    </div>\n  );\n  }\n\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Voyage.js",["118"],"/* eslint-disable jsx-a11y/alt-text */\nimport React from 'react';\nimport ReactPlayer from 'react-player';\nimport './Voyage.css';\nimport voyage from './voyage.jpg';\nimport Topbar from './Topbar';\nimport Footer from './Footer';\nimport GoToTop from './GoToTop';\n\n\n\nexport default function Voyage() {\n  return (\n    <div className='voyage-container'>\n      <GoToTop />\n      <div className=\"voyage-banner\" >\n       <Topbar />\n        <ReactPlayer\n          url='voyage2.mp4'\n          className=\"video\"\n          width=\"100%\"\n          height=\"100%\"\n          object-fit=\"cover\"\n          muted={true}\n          playing={true}\n          loop={true}\n          controls={false}\n          allowfullscreen={true} />\n      </div>\n      <div className=\"content-tambour\">\n        <div>\n          <img className='image-profile-voyage' src={voyage} alt='moi avec un tambour' />\n        </div>\n\n        <div className='voyage-content'>\n          <h2>  La magie du son du tambour </h2> <br />\n\n         <p> Partir rencontrer son animal totem, échanger avec les esprits, trouver des messages, les vibrations du tambour t'emportera dans un univers magique. Issu des traditions chamaniques, le voyage au tambour nous permet de cheminer dans ce qui est appelé le \"monde invisible\". Les chamanes sont considéré.e.s comme étant des guériss.eurs.euses pouvant communiquer avec les esprits. On retrouve encore ces traditions chez certaines populations autochtones.</p>\n\n          <p> Depuis les recherches ont avancé, apportant plus d'explications sur ce qui se passe au niveau cérébral lorsqu'on effectue un voyage. Les vibrations émises par le tambour nous mènent à ce qu'on appelle un état modifié de conscience nous plongeant ainsi dans une sorte de rêve, voir de transe.</p>\n\n          <p> C'est une expérience qui reste unique pour chacun.e et les ressentis sont différents. On peut y trouver <strong>un état de relaxation, un travail sur le lâcher prise, un arrêt du brouhaha mental, des réponses à nos questions, une meilleure compréhension de nos états émotionnels</strong>...Vous venez y chercher ce que vous souhaitez ! </p>\n\n          <a href=\"https://www.instagram.com/ana.resonance/\" target=\"_blank\" rel=\"noopener\"><button className=\"btn btn--follow\">\n            ▻▻ Suivre les prochaines sessions\n          </button></a>\n        </div>\n      </div>\n      <Footer />\n    </div>\n  );\n}\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Coaching.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Events.js",["119","120"],"import React from 'react';\nimport { useEffect } from \"react\";\nimport './Events.css';\nimport Programme from './Programme.png';\nimport Metta from './Metta.png'\nimport picture7 from './picture7.JPG';\nimport Topbar from './Topbar';\nimport Footer from './Footer';\nimport instagram from './instagram.svg';\n\n\n\nfunction Events() {\n\n\n\n  function ScrollToTopOnMount() {\n    useEffect(() => {\n      window.scrollTo(0, 0);\n    }, []);\n\n    return null;\n  }\n\n\n\n  return (\n    <div className=\"events-container\" id=\"events\">\n      <ScrollToTopOnMount />\n      {/* ---Banner--- */}\n      <div className='banner-container3'>\n        <div className=\"image-banner-events\" >\n          <Topbar />\n          <img src={Programme} className=\"image-events\" alt=\"bannière avec de la peinture ocre en arrière plan avec l'intitulé Programme\" />\n        </div>\n      </div>\n      {/* ---------------- */}\n      <h1 className='apropos-title2'> Un programme varié et intense !</h1>\n      <div className=\"cards-content-events\">\n        <div className=\"photo-metta\">\n          <img src={Metta} className=\"image-metta\" alt=\" logo du programme metta\" />\n          <img src={picture7} className=\"image-metta2\" alt=\"moi les bras croisés\" />\n        </div>\n        <div className=\"content-metta\">\n          <h3> Quel est l'objectif ?</h3>\n          <p>\n            Ce programme est destiné à toutes les personnes qui souhaitent se sentir plus aligné.e et bien dans leur vie. Que ce soit pour être bien avec soi-même, mieux te connaître ou réaliser des projets qui ont du sens pour toi. Seulement tu bloques et tu as l'impression de stagner. <strong>Ce suivi particulier mêlant yoga, thérapie par le son et coaching </strong> permet d'aller plus loin dans ta quête de sens et d'amour de soi. \"Metta\" voulant dire \"amour bienveillant et adelphité\" en Pali (\"Maitri\" en sanskrit), c'est la vision que je souhaite donner à ce programme.</p>\n\n          <h3> Comment ça se déroule ?</h3>\n\n          <p> <strong>Sur une période de 4 mois</strong>, tu seras suivi.e individuellement avec des sessions collectives.\n            En fonction de tes besoins, tu auras accès à des sessions de yoga, de coaching et de voyage au tambour. Un point sera fait de façon régulière et tu auras accès à du contenu écrit pour t'aider à bénéficier des effets du programme dans ton quotidien.</p>\n          <li> Il y aura 12 ateliers répartis sur les 4 mois. </li>\n          <li> Un point individuel toutes les 2 semaines. </li>\n          <li> Un appel de groupe une fois par mois.</li>\n          <li> L'accès à une communauté pour vous apporter du soutien.</li>\n          <li>Un bilan à la fin du programme.</li> <br />\n\n\n          <h3> Est-ce fait pour toi ? </h3>\n          <p> Il est n'est pas facile de trouver le temps et l'énergie d'avancer dans ses projets, d'y voir clair, de se sentir légitime et d'oser des changements profonds sur soi. Alors tu abandonnes, laissant tes projets et problèmes de côté. <strong> Avoir un suivi permet de véritablement avancer sans se mettre de pression.</strong> Cela te permettra de découvrir de nouveaux outils de développement personnel avec une vision féministe, que ce soit par le corps, par l'esprit ou par la parole. Si tu sens que tu as besoin d'être accompagné.e, qu'on te donne des objectifs, d'échanger et que tu es curieu.x.se d'explorer alors ce programme est fait pour toi. Tu pourras de même rencontrer d'autres personnes partageant les même problématiques que toi et vous soutenir !\n          </p> <br />\n\n          <h3> Pour quel résultat ? </h3>\n          <p> À la fin <strong>tu auras les idées plus claires, des outils pour avancer dans des projets qui ont du sens, tu te sentiras plus aligné.e, inspiré.e et confiant.e.</strong> Tu repartiras boosté.e comme jamais. 🙌\n          </p> <br />\n\n          <blockquote><h5> Le programme n'est pas encore ouvert mais n'hésite pas à t'abonner à mon compte insta pour être au courant de la prochaine session 💫 </h5></blockquote>\n\n            <a href=\"https://www.instagram.com/ana.resonance/\" style={{ marginBottom: 30 }} target=\"_blank\" rel=\"noopener\">\n            <button className=\"btn btn--follow\">\n              ▻▻ Me suivre pour en savoir plus\n            </button></a>\n        </div>\n      </div>\n      <Footer />\n    </div>\n  )\n}\n\nexport default Events;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Topbar.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Content.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Profile2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/OnePost.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/AllPosts.js",["121"],"/* eslint-disable jsx-a11y/img-redundant-alt */\n// src/components/AllPosts.js\n\nimport React, { useEffect, useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport sanityClient from \"./Client.js\";\nimport Topbar from './Topbar';\nimport './Content.css';\nimport ressources2 from './ressources2.png';\nimport Footer from './Footer';\n\nexport default function AllPosts() {\n  const [allPostsData, setAllPosts] = useState(null);\n\n  useEffect(() => {\n    sanityClient\n      .fetch(\n        `*[_type == \"post\"]{\n        title,\n        slug,\n        mainImage{\n          asset->{\n          _id,\n          url\n        }\n      }\n    }`\n      )\n      .then((data) => setAllPosts(data))\n      .catch(console.error);\n  }, []);\n\n  return (\n    <>\n    <div className=\"events-container min-h-screen \" id=\"events\">\n          <div className='banner-container3'>\n            <div className=\"image-banner-content\" >\n              <Topbar />\n              <img src={ressources2} alt=\"Image de la bannière avec un café en fond pour la page blog\"/>\n            </div>\n          </div>\n        <div className=\"cards-content\">\n          <div className=\"text-metta\">\n            <div className=\"title-metta\">\n              <li> Bien-être </li><span> // </span><li> Empowerment </li>\n            </div>\n          </div>\n          <div className=\"content-metta\">\n            <div className=\"container-cards-blog\">\n\n          <div className=\"card-blog\">\n\n          {allPostsData &&\n            allPostsData.map((post, index) => (\n                <span\n                  className=\"block h-64 relative rounded shadow leading-snug bg-white\"\n                  key={index}\n                >\n\n                <Link to={\"/\" + post.slug.current } key={post.slug.current}>\n                  <img\n                    className=\"w-full h-full rounded-r object-cover absolute\"\n                    src={post.mainImage.asset.url}\n                    alt=\"Image des posts du blog pour mettre en avant les titres\"\n                  />\n                  </Link>\n                  <span\n                    className=\"block relative h-full flex justify-end items-end pr\n                      -4 pb-4\">\n                  </span>\n                <h1>\n                  {post.title}\n                </h1>\n               </span>\n            )) }\n         </div>\n        </div>\n        </div>\n        </div>\n        <Footer />\n      </div>\n    </>\n  );\n}\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Client.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Popup.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/404_page.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/PreLoader.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/GoToTop.js",[],{"ruleId":"122","replacedBy":"123"},{"ruleId":"124","replacedBy":"125"},{"ruleId":"126","severity":1,"message":"127","line":20,"column":65,"nodeType":"128","endLine":20,"endColumn":138},{"ruleId":"126","severity":1,"message":"127","line":21,"column":58,"nodeType":"128","endLine":21,"endColumn":129},{"ruleId":"126","severity":1,"message":"127","line":22,"column":68,"nodeType":"128","endLine":22,"endColumn":143},{"ruleId":"126","severity":1,"message":"127","line":23,"column":77,"nodeType":"128","endLine":23,"endColumn":158},{"ruleId":"126","severity":1,"message":"127","line":31,"column":13,"nodeType":"128","endLine":31,"endColumn":85},{"ruleId":"126","severity":1,"message":"127","line":8,"column":9,"nodeType":"128","endLine":8,"endColumn":222},{"ruleId":"129","severity":1,"message":"130","line":54,"column":11,"nodeType":"128","messageId":"131","endLine":54,"endColumn":93,"fix":"132"},{"ruleId":"129","severity":1,"message":"130","line":44,"column":11,"nodeType":"128","messageId":"131","endLine":44,"endColumn":93,"fix":"133"},{"ruleId":"134","severity":1,"message":"135","line":9,"column":8,"nodeType":"136","messageId":"137","endLine":9,"endColumn":17},{"ruleId":"129","severity":1,"message":"130","line":70,"column":13,"nodeType":"128","messageId":"131","endLine":70,"endColumn":124,"fix":"138"},{"ruleId":"139","severity":1,"message":"140","line":45,"column":41,"nodeType":"141","messageId":"142","endLine":45,"endColumn":45},"no-native-reassign",["143"],"no-negated-in-lhs",["144"],"jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","JSXOpeningElement","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","noTargetBlank",{"range":"145","text":"146"},{"range":"147","text":"146"},"no-unused-vars","'instagram' is defined but never used.","Identifier","unusedVar",{"range":"148","text":"146"},"react/jsx-no-comment-textnodes","Comments inside children section of tag should be placed inside braces","Literal","putCommentInBraces","no-global-assign","no-unsafe-negation",[2883,2893],"\"noopener noreferrer\"",[2195,2205],[4084,4094]]