fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"89","messages":"90","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"91","messages":"92","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"95","messages":"96","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"97","messages":"98","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"103","messages":"104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"105","messages":"106","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},"/Users/admin/code/Audrey-hello/web-site/src/index.js",[],["107","108"],"/Users/admin/code/Audrey-hello/web-site/src/reportWebVitals.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/App.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Contact.js",["109"],"import React, { useState } from 'react';\nimport { useForm } from 'react-hook-form';\nimport './Contact.css';\nimport Topbar from './Topbar';\nimport Footer from './Footer';\nimport { init, sendForm } from 'emailjs-com';\ninit(\"user_Boc5zsTh76kXC3qdiR1Fa\");\n\n\n\nconst Contact = () => {\n\n\n  const { register, handleSubmit, watch, formState: { errors } } = useForm(\"\");\n  const onSubmit = data => {\n  console.log(data);\n\n  const statusMessage = document.querySelector('.status-message');\n  const form = document.querySelector('#contact-form');\n  generateContactNumber();\n  sendForm('default_service', 'template_32681fl', '#contact-form')\n    .then(function (response) {\n      console.log('SUCCESS!', response.status, response.text);\n      form.reset();\n      setStatusMessage(\"Message envoyé!\");\n      statusMessage.className = \"status-message success\";\n      setTimeout(() => {\n        statusMessage.className = 'status-message'\n      }, 5000)\n    }, function (error) {\n      console.log('FAILED...', error);\n      setStatusMessage(\"Le message n'est pas passé...retentez !\");\n      statusMessage.className = \"status-message failure\";\n      setTimeout(() => {\n        statusMessage.className = 'status-message'\n      }, 10000)\n    });\n}\n\n  const validator = require(\"email-validator\");\n  ;\n  const message = watch('message') || \"\";\n  const messageCharsLeft = 1500 - message.length;\n  const [contactNumber, setContactNumber] = useState(\"000000\");\n  const [statusMessage, setStatusMessage] = useState(\"Message\");\n  const generateContactNumber = () => {\n  const numStr = \"000000\" + (Math.random() * 1000000 | 0);\n  setContactNumber(numStr.substring(numStr.length - 6));\n}\n\n  return (\n    <>\n     <div className=\"entete\">\n       <Topbar />\n      </div>\n    <div className='contact'>\n      <strong><h1 className='title-contact'>Contact</h1></strong>\n       <p className='status-message'>{statusMessage}</p>\n      <div className=\"container-contact-form\">\n        <form id='contact-form' onSubmit={handleSubmit(onSubmit)}>\n          <input type='hidden' name='contact_number' value={contactNumber} />\n          {errors.user_name && errors.user_name.type === \"required\" && (\n            <div role=\"alert\">Name is required<br /></div>\n          )}\n          <p> Nom complet* </p>\n\n          <div className=\"nom_complet\">\n            <span className=\"container-prénom\">\n              <input\n              type='text'\n              className=\"input-prénom\"\n              name='user_firstname'\n              ref={register('')}\n              maxLength='30'\n              aria-invalid={errors.user_firstname ? \"true\" : \"false\"}\n              { ...register('user_firstname', { required: true } )}\n                  />\n              <label className=\"prénom\">  Prénom </label>\n            </span>\n            <span className=\"container-nom\">\n              <input\n                type='text'\n                className=\"input-nom\"\n                name='user_lastname'\n                ref={register('')}\n                maxLength='30'\n                aria-invalid={errors.user_lastname ? \"true\" : \"false\"}\n                {...register('user_lastname', { required: true })}\n                />\n              <label className=\"nom\"> Nom </label></span>\n          </div>\n          <br />\n          <div className=\"input-container\">\n            <p> Email* </p>\n            <input type='email' name='user_email' ref={register('a@gmail.com')} onChange={validator.validate(\"test@email.com\")}  />\n            <br />\n            <p className=\"label-message\"> Message* </p>\n          <div className=\"message-container\">\n            <textarea id=\"input-message\" name='message' ref={register('a@gmail.com')} maxLength='1500' />\n          </div>\n          <br />\n            <input type='submit' value='Envoyer' className=\"envoyer\" />\n          </div>\n        </form>\n      </div>\n      <Footer />\n    </div>\n  </>\n  );\n}\nexport default Contact;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/pages/Home.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Banner.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Profile.js",["110"],"import { Link } from 'react-router-dom';\nimport React from 'react';\nimport './Profile.css';\nimport picture11 from './picture11.JPG';\nimport Footer from './Footer';\n\nfunction Profile() {\n  return (\n    <div>\n      <div className='profile-grid'>\n        <div className='profile-content'>\n          <h1> Qui suis-je ? </h1>\n\n          <p>Je m’appelle Ana et je suis passionnée par ce qui nous permet de prendre conscience du monde qui nous entoure et de ce qui nous aide à nous sentir bien. Après avoir travaillé pendant plusieurs années en finance, j’ai démissionné et décidé de changer de façon radicale ma façon de vivre plus alignée avec qui j'étais.</p>\n          <p>Je me définis comme étant féministe, empathique, ambitieuse et entrepreneuse. J'aime accompagner les femmes et minorités de genre à révéler leur potentiel et à prendre leur place ! </p>\n          <div className='cards-btns'>\n            <Link to='/profile2' className='btn-mobile'>\n              <button className=\"btn btn--inline\">\n                Viens voir mon profil !\n              </button>\n            </Link>\n          </div>\n        </div>\n        <div>\n          <img className='image-profile-home' src={picture11} alt='profile' />\n        </div>\n      </div>\n    </div>\n\n  )\n}\n\nexport default Profile;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Cards.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Footer.js",["111","112","113","114"],"/* eslint-disable jsx-a11y/alt-text */\nimport { Link } from 'react-router-dom';\nimport './Footer.css';\nimport instagram from './instagram.svg';\nimport facebook from './facebook.svg';\nimport mail from './mail.svg';\nimport pinterest from './pinterest.svg';\n\n\nfunction Footer() {\n  return (\n    <div className='footer-container'>\n      <div className=\"logo-footer\">\n        <h1 className=\"title-logo\">Résonance </h1>\n      </div>\n      <div className=\"footer-links\">\n        <h2 className=\"title-footer\"> Me suivre </h2>\n        <div className=\"social-media-footer\">\n          <a href=\"https://www.instagram.com/ana.resonance/\"><i><img src={instagram} className=\"social-logo\" alt=\"image du logo insta\" /></i></a>\n          <a href=\"https://www.facebook.com/resonance.anahata\" ><i><img src={facebook} className=\"social-logo\" alt=\"image du logo facebook\" /></i></a>\n          <a href=\"https://www.pinterest.fr/anahataresonance/_created/\" ><i><img src={pinterest} className=\"social-logo-pint\" alt=\"image du logo facebook\" /></i></a>\n        </div>\n      </div>\n      <div className=\"contact-content\">\n        <div className=\"contacter\">\n          <h2 className=\"title-footer\" id='footer'>Me contacter</h2>\n          <div className=\"social-logo-mail\" >\n            <Link to={'/Contact'} >\n            <img src={mail} className=\"social-logo-mail\" alt=\"image du logo mail\" />\n            </Link>\n          </div>\n        </div>\n      </div>\n      <div className=\"mentions-légales\">\n        <h2 className=\"title-mention\" > Conditions générales du site </h2>\n        <div className=\"block-lien-mention\">\n          <a href=\"https://docs.google.com/document/d/1d9N3qxisZQ_xxm1bSfb7_k7EeZe5O4-B4vTLXVc2oCk/edit?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Mentions légales</a>\n          <a href=\"https://drive.google.com/file/d/148ZLMYZs71JNm87HV19-L-t_PTVNaJMc/view?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Politique de confidentialité\n          </a>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Banner2.js",["115"],"import React from 'react';\nimport './Banner.css';\n\nfunction Banner2() {\n  return (\n    <div className='banner-container2'>\n      <div className=\"image-banner2\" >\n        <img src=\"https://images.unsplash.com/photo-1517363898874-737b62a7db91?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1558&q=80\" alt=\"image unsplash d'une femme méditant\"/>\n      </div>\n    </div>\n  )\n};\n\nexport default Banner2;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Button.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Yoga.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Voyage.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Coaching.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Events.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Topbar.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Content.js",["116"],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Profile2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/OnePost.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/AllPosts.js",["117"],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Client.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Popup.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/404_page.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/PreLoader.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/GoToTop.js",[],{"ruleId":"118","replacedBy":"119"},{"ruleId":"120","replacedBy":"121"},{"ruleId":"122","severity":1,"message":"123","line":43,"column":9,"nodeType":"124","messageId":"125","endLine":43,"endColumn":25},{"ruleId":"122","severity":1,"message":"126","line":5,"column":8,"nodeType":"124","messageId":"125","endLine":5,"endColumn":14},{"ruleId":"127","severity":1,"message":"128","line":19,"column":65,"nodeType":"129","endLine":19,"endColumn":138},{"ruleId":"127","severity":1,"message":"128","line":20,"column":68,"nodeType":"129","endLine":20,"endColumn":143},{"ruleId":"127","severity":1,"mes