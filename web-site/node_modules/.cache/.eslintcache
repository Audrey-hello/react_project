[{"/Users/admin/code/Audrey-hello/web-site/src/index.js":"1","/Users/admin/code/Audrey-hello/web-site/src/reportWebVitals.js":"2","/Users/admin/code/Audrey-hello/web-site/src/components/App.js":"3","/Users/admin/code/Audrey-hello/web-site/src/components/AllPosts.js":"4","/Users/admin/code/Audrey-hello/web-site/src/components/OnePost.js":"5","/Users/admin/code/Audrey-hello/web-site/src/components/Profile2.js":"6","/Users/admin/code/Audrey-hello/web-site/src/components/Client.js":"7","/Users/admin/code/Audrey-hello/web-site/src/components/Footer.js":"8","/Users/admin/code/Audrey-hello/web-site/src/components/Topbar.js":"9","/Users/admin/code/Audrey-hello/web-site/src/components/Popup.js":"10","/Users/admin/code/Audrey-hello/web-site/src/components/Button.js":"11","/Users/admin/code/Audrey-hello/web-site/src/components/GoToTop.js":"12","/Users/admin/code/Audrey-hello/web-site/src/components/Cards.js":"13","/Users/admin/code/Audrey-hello/web-site/src/components/Banner2.js":"14","/Users/admin/code/Audrey-hello/web-site/src/components/Profile.js":"15","/Users/admin/code/Audrey-hello/web-site/src/components/Banner.js":"16","/Users/admin/code/Audrey-hello/web-site/src/pages/Home.js":"17","/Users/admin/code/Audrey-hello/web-site/src/pages/Yoga.js":"18","/Users/admin/code/Audrey-hello/web-site/src/pages/Contact.js":"19","/Users/admin/code/Audrey-hello/web-site/src/pages/Programme.js":"20","/Users/admin/code/Audrey-hello/web-site/src/pages/Coaching.js":"21","/Users/admin/code/Audrey-hello/web-site/src/pages/Voyage.js":"22","/Users/admin/code/Audrey-hello/web-site/src/pages/404_page.js":"23","/Users/admin/code/Audrey-hello/web-site/src/pages/Content.js":"24"},{"size":562,"mtime":1634835083511,"results":"25","hashOfConfig":"26"},{"size":362,"mtime":1626596782611,"results":"27","hashOfConfig":"26"},{"size":2018,"mtime":1642780228801,"results":"28","hashOfConfig":"26"},{"size":2431,"mtime":1640687820656,"results":"29","hashOfConfig":"26"},{"size":5427,"mtime":1640798289238,"results":"30","hashOfConfig":"26"},{"size":3903,"mtime":1648646432082,"results":"31","hashOfConfig":"26"},{"size":252,"mtime":1628341120513,"results":"32","hashOfConfig":"26"},{"size":2181,"mtime":1640693955092,"results":"33","hashOfConfig":"26"},{"size":3480,"mtime":1652296575840,"results":"34","hashOfConfig":"26"},{"size":331,"mtime":1640694163335,"results":"35","hashOfConfig":"26"},{"size":668,"mtime":1640687900315,"results":"36","hashOfConfig":"26"},{"size":280,"mtime":1629752232024,"results":"37","hashOfConfig":"26"},{"size":4273,"mtime":1648145874434,"results":"38","hashOfConfig":"26"},{"size":349,"mtime":1652218008452,"results":"39","hashOfConfig":"26"},{"size":1461,"mtime":1652216584812,"results":"40","hashOfConfig":"26"},{"size":387,"mtime":1648155622240,"results":"41","hashOfConfig":"26"},{"size":443,"mtime":1640805038358,"results":"42","hashOfConfig":"26"},{"size":3234,"mtime":1652263526889,"results":"43","hashOfConfig":"26"},{"size":3941,"mtime":1640694528586,"results":"44","hashOfConfig":"26"},{"size":4715,"mtime":1652217225451,"results":"45","hashOfConfig":"26"},{"size":7629,"mtime":1652220985711,"results":"46","hashOfConfig":"26"},{"size":2399,"mtime":1648156531331,"results":"47","hashOfConfig":"26"},{"size":556,"mtime":1640688259307,"results":"48","hashOfConfig":"26"},{"size":2349,"mtime":1648150968199,"results":"49","hashOfConfig":"26"},{"filePath":"50","messages":"51","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},"ylw4d0",{"filePath":"53","messages":"54","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"55","messages":"56","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"57","messages":"58","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"59","usedDeprecatedRules":"52"},{"filePath":"60","messages":"61","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"62","messages":"63","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"68","usedDeprecatedRules":"52"},{"filePath":"69","messages":"70","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"71","messages":"72","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"73","messages":"74","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"75","messages":"76","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"77","messages":"78","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"79","usedDeprecatedRules":"52"},{"filePath":"80","messages":"81","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"82","messages":"83","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"84","messages":"85","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"86","messages":"87","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"88","messages":"89","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"90"},{"filePath":"91","messages":"92","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"93","messages":"94","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"95","usedDeprecatedRules":"52"},{"filePath":"96","messages":"97","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"98","messages":"99","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"100","usedDeprecatedRules":"52"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"103","messages":"104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},"/Users/admin/code/Audrey-hello/web-site/src/index.js",[],["105","106"],"/Users/admin/code/Audrey-hello/web-site/src/reportWebVitals.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/App.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/AllPosts.js",["107"],"/* eslint-disable jsx-a11y/img-redundant-alt */\n// src/components/AllPosts.js\n\nimport React, { useEffect, useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport sanityClient from \"./Client.js\";\nimport Topbar from './Topbar';\nimport '../styles/Content.css';\nimport ressources2 from '../img/ressources2.png';\nimport Footer from './Footer';\n\nexport default function AllPosts() {\n  const [allPostsData, setAllPosts] = useState(null);\n\n  useEffect(() => {\n    sanityClient\n      .fetch(\n        `*[_type == \"post\"]{\n        title,\n        slug,\n        mainImage{\n          asset->{\n          _id,\n          url\n        }\n      }\n    }`\n      )\n      .then((data) => setAllPosts(data))\n      .catch(console.error);\n  }, []);\n\n  return (\n    <>\n    <div className=\"events-container min-h-screen \" id=\"events\">\n          <div className='banner-container3'>\n            <div className=\"image-banner-content\" >\n              <Topbar />\n              <img src={ressources2} alt=\"Image de la bannière avec un café en fond pour la page blog\"/>\n            </div>\n          </div>\n        <div className=\"cards-content\">\n          <div className=\"text-metta\">\n            <div className=\"title-metta\">\n              <li> Bien-être </li><span> // </span><li> Empowerment </li>\n            </div>\n          </div>\n          <div className=\"content-metta\">\n            <div className=\"container-cards-blog\">\n\n          <div className=\"card-blog\">\n\n          {allPostsData &&\n            allPostsData.map((post, index) => (\n                <span\n                  className=\"block h-64 relative rounded shadow leading-snug bg-white\"\n                  key={index}\n                >\n\n                <Link to={\"/\" + post.slug.current } key={post.slug.current}>\n                  <img\n                    className=\"w-full h-full rounded-r object-cover absolute\"\n                    src={post.mainImage.asset.url}\n                    alt=\"Image des posts du blog pour mettre en avant les titres\"\n                  />\n                  </Link>\n                  <span\n                    className=\"block relative h-full flex justify-end items-end pr\n                      -4 pb-4\">\n                  </span>\n                <h1>\n                  {post.title}\n                </h1>\n               </span>\n            )) }\n         </div>\n        </div>\n        </div>\n        </div>\n        <Footer />\n      </div>\n    </>\n  );\n}\n","/Users/admin/code/Audrey-hello/web-site/src/components/OnePost.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Profile2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Client.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Footer.js",["108","109","110"],"/* eslint-disable jsx-a11y/alt-text */\nimport { Link } from 'react-router-dom';\nimport '../styles/Footer.css';\nimport instagram from '../img/instagram.svg';\nimport facebook from '../img/facebook.svg';\nimport mail from '../img/mail.svg';\nimport pinterest from '../img/pinterest.svg';\nimport tiktok from '../img/tiktok.svg';\n\n\nfunction Footer() {\n  return (\n    <div className='footer-container'>\n      <div className=\"logo-footer\">\n        <h1 className=\"title-logo\">Résonance </h1>\n      </div>\n      <div className=\"footer-links\">\n        <h2 className=\"title-footer\"> Me suivre </h2>\n        <div className=\"social-media-footer\">\n          <a href=\"\"><i><img src={instagram} className=\"social-logo\" alt=\"logo insta\" /></i></a>\n          <a href=\"\" ><i><img src={tiktok} className=\"social-logo\" alt=\"logo tiktok\" /></i></a>\n          <a href=\"https://www.facebook.com/resonance.anahata\" ><i><img src={facebook} className=\"social-logo\" alt=\"logo facebook\" /></i></a>\n          <a href=\"\" ><i><img src={pinterest} className=\"social-logo-pint\" alt=\"logo facebook\" /></i></a>\n        </div>\n      </div>\n      <div className=\"contact-content\">\n        <div className=\"contacter\">\n          <h2 className=\"title-footer\" id='footer'>Me contacter</h2>\n          <div className=\"social-logo-mail\" >\n            <Link to={'/Contact'} >\n            <img src={mail} className=\"social-logo-mail\" alt=\"logo mail\" />\n            </Link>\n          </div>\n        </div>\n      </div>\n      <div className=\"mentions-légales\">\n        <h2 className=\"title-mention\" > Conditions générales du site </h2>\n        <div className=\"block-lien-mention\">\n          <a href=\"https://docs.google.com/document/d/1d9N3qxisZQ_xxm1bSfb7_k7EeZe5O4-B4vTLXVc2oCk/edit?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Mentions légales</a>\n          <a href=\"https://drive.google.com/file/d/148ZLMYZs71JNm87HV19-L-t_PTVNaJMc/view?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Politique de confidentialité\n          </a>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n","/Users/admin/code/Audrey-hello/web-site/src/components/Topbar.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Popup.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Button.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/GoToTop.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Cards.js",["111","112"],"/* eslint-disable jsx-a11y/alt-text */\nimport React from 'react';\nimport { Link } from 'react-router-dom';\nimport '../styles/Cards.css';\nimport tambour from '../img/tambour.jpg';\nimport instagram from '../img/instagram.svg';\nimport facebook from '../img/facebook.svg';\n\n\n\nfunction Cards() {\n\n\n  return (\n    <div className=\"cards-container\">\n      <h1 className='apropos-title' id='cards'> Programme </h1>\n      <p className=\"themes\"> Les différentes thématiques alliant le corps, le rapport à soi et aux autre, son identité. </p>\n      <div className=\"title-container\">\n        <h3 className=\"rubrique-title\">LES ATELIERS </h3>\n      </div>\n      <div className=\"cards-content\">\n        <div className='cards'>\n\n          <Link to={'/Yoga'}>\n          <div className=\"card-ateliers-yoga\">\n            <p className=\"title-cards\"><strong> Yoga Vinyasa </strong></p>\n              <img src=\"https://images.unsplash.com/photo-1603988363607-e1e4a66962c6?ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&ixlib=rb-1.2.1&auto=format&fit=crop&w=1500&q=80\" className=\"image-yoga\" alt=\"une femme faisant du yoga pour les ateliers yoga\"/>\n            <div className=\"text\">\n              <p> Yoga dynamique enchaînant différents flows pour t'aider à gagner en confiance en soi, te relaxer et avoir un meilleur rapport à ton corps. Le but est de progresser à ton rythme avec fun et bienveillance. </p>\n            </div>\n          </div>\n           </Link>\n\n          <Link to={'/Voyage'}>\n          <div className=\"card-ateliers-chaman\">\n            <p className=\"title-cards\"><strong> Voyage au tambour  </strong></p>\n            <img src={tambour} className=\"image-tambour\" alt=\"un tambour chamanique pour les ateliers voyage au tambour\"/>\n            <div className=\"text\">\n              <p> Voyage au son du tambour afin de te connecter à ton monde intérieur, te réancrer, lâcher prise et comprendre ce qui se passe en toi grâce aux vibrations. Si tu ne connais pas viens explorer !</p>\n            </div>\n          </div>\n          </Link>\n\n          <Link to={'/Coaching'}>\n          <div className=\"card-ateliers\">\n              <p className=\"title-cards\"><strong> Accompagnement 1:1  </strong></p>\n            <img src=\"https://images.unsplash.com/photo-1573164574230-db1d5e960238?ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&ixlib=rb-1.2.1&auto=format&fit=crop&w=1050&q=80\" className=\"image-yoga\" alt=\"ambiance de travail pour les ateliers coaching\" />\n            <div>\n                <p className=\"text\"> Te libérer de tout ce qui t'empêche de te sentir toi-même…et de prendre ta place. Ces ateliers te donneront des outils pour te sentir plus affirmé.e et avancer dans tes projets.</p>\n            </div>\n          </div>\n          </Link>\n        </div>\n\n        <div className=\"Retraites\">\n          <div className=\"title-container2\">\n            <h3 className=\"rubrique-title-retraites\"> LES RETRAITES  </h3>\n            <img src=\"https://images.unsplash.com/reserve/m6rT4MYFQ7CT8j9m2AEC_JakeGivens%20-%20Sunset%20in%20the%20Park.JPG?ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&ixlib=rb-1.2.1&auto=format&fit=crop&w=753&q=80\" className=\"image-retraites\" alt=\"prairie au lever du soleil\" />\n          </div>\n          <div className=\"text-retraite\">\n\n            <p> Au sein d’un lieu ressourçant dans la nature, je propose des week-ends alliant bien-être et un cadre de réflexion sur le thème du moment. </p>\n            <p> Entre cours de yoga, cuisine végie, ateliers divers, ces immersions permettent d'aller encore plus loin dans son apprentissage. Mais c'est aussi avec l'aide de tout un groupe de personnes partageant les mêmes valeurs et la même envie de partage que nous nous réunissons !</p> <br />\n\n            <p> <strong>N'hésite pas à me suivre sur les réseaux pour être informé.e. des prochaines sessions !</strong> </p>\n\n            <div className=\"social-media-retraite\">\n              <a href=\"\" ><i><img src={instagram} className=\"social-logo-retraite\" alt=\"logo instagram\"/></i></a>\n              <a href=\"\" ><i><img src={facebook} className=\"social-logo-retraite\" alt=\"logo facebook\"/></i></a>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n\n\n  )\n}\n\nexport default Cards;\n","/Users/admin/code/Audrey-hello/web-site/src/components/Banner2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Profile.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Banner.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Home.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Yoga.js",["113"],"/* eslint-disable react/style-prop-object */\nimport React from 'react';\nimport \"../styles/Yoga.css\";\nimport ReactPlayer from 'react-player';\nimport yoga from '../img/yoga.png';\nimport Topbar from '../components/Topbar';\nimport Footer from '../components/Footer';\nimport GoToTop from '../components/GoToTop';\n\n\n\n\nexport default function Yoga() {\n  return (\n    <div className='yoga-container' >\n      <GoToTop />\n      <div className=\"yoga-banner\" id='yoga'>\n        <Topbar />\n        <ReactPlayer\n          url='yoga.mp4'\n          className=\"video\"\n          width=\"100%\"\n          height=\"100%\"\n          object-fit=\"cover\"\n          muted={true}\n          playing={true}\n          loop={true}\n          controls={false}\n          allowfullscreen={true}/>\n      </div>\n      <div className=\"content-yoga\">\n        <div className='profile-content-yoga'>\n          <h2>  Connexion au corps et à l'esprit  </h2> <br />\n\n          <p>Le Vinyasa yoga est une pratique dynamique issue de l'Ashtanga enchaînant les asanas avec créativité et fluidité. Cela permet de relâcher les tensions, se réancrer et se reconnecter à son corps. Cela contribue ainsi à une meilleure santé mentale, à la gestion de ses émotions, et à apprendre à aimer son corps. <strong>C'est donc un véritable outil aidant la confiance en soi ! </strong></p><br />\n\n          <h3> Les valeurs que je divulgue par le yoga </h3><br />\n\n          <p> Le yoga n'est pas juste un outil bien-être, c'est une philosophie indienne qui existe depuis des siècles. Si les postures font référence à l'aspect physique lié au corps, à la discipline, à la respiration il y a aussi tout un aspect plus spirituel. <strong><mark>Les valeurs de bienveillance, de respect, de compassion, de non-jugement sont tout aussi importantes pour moi dans cette pratique.</mark> </strong> </p> <br />\n          <p> De même, le yoga est ouvert à tout le monde quelque soit ta morphologie, niveau...Aussi je trouve important de respecter les racines de cette pratique et éviter l'appropriation culturelle en se centrant uniquement sur l'aspect physique. <strong> Le yoga est représenté dans la diversité ! </strong>De même, il n' y a pas de compétition en yoga, <strong> tu y vas à ton rythme </strong>en fonction de ta pratique.</p>\n\n\n          <li>Je propose des cours collectif de débutant.e à intermédiaire.</li><br />\n          <li>Des cours individuels sont aussi proposés dans une optique d'accompagnement.</li><br />\n          <li>Pour bénéficier de plusieurs outils complémentaires au yoga, rejoignez le programme !</li><br />\n\n          <h3> Ressources </h3><br />\n\n          <p> -  Susanna Barkataki  et son livre \"Embrace Yoga's Roots: Courageous Ways to Deepen Your Yoga Practice\".</p>\n          <p> - Le compte yogaisdeadpodcast. </p>\n          <p> - Henikapetal avec School of Sensual Arts.</p>\n\n          <a href=\"\" target=\"_blank\" rel=\"noopener\"><button  className=\"btn btn--follow\">\n            ▻▻ Suivre les prochaines sessions\n          </button></a>\n\n        </div>\n        <div>\n          <img className='image-profile-yoga2' src={yoga} alt=\"Pause yoga d'une femme\" />\n        </div>\n      </div>\n      <Footer />\n    </div>\n  );\n  }\n\n","/Users/admin/code/Audrey-hello/web-site/src/pages/Contact.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Programme.js",["114"],"import React from 'react';\nimport { useEffect } from \"react\";\nimport '../styles/Programme.css';\nimport cover from '../img/CoverB&C.png';\nimport BandC from '../img/Boost&Care.png'\nimport group from '../img/Boost&care_group.jpg';\nimport Topbar from '../components/Topbar';\nimport Footer from '../components/Footer';\n\n\n\nfunction Programme() {\n\n\n  function ScrollToTopOnMount() {\n    useEffect(() => {\n      window.scrollTo(0, 0);\n    }, []);\n\n    return null;\n  }\n\n\n  return (\n    <div className=\"events-container\" id=\"events\">\n      <ScrollToTopOnMount />\n      {/* ---Banner--- */}\n      <div className='banner-container3'>\n        <div className=\"image-banner-events\" >\n          <Topbar />\n          <img src={cover} className=\"image-events\" alt=\"bannière avec de la peinture ocre en arrière plan avec l'intitulé Programme\" />\n        </div>\n      </div>\n      {/* Contenu de du programme---------------- */}\n      <div className=\"programme-container\">\n        <h1 className='apropos-title2'> Un programme alliant soin de soi et coup de boost !</h1><br />\n        <div className=\"cards-content-events\">\n          <div className=\"photo-metta\">\n            <img src={BandC} className=\"image-metta\" alt=\" logo du programme metta\" />\n            <img src={group} className=\"image-metta2\" alt=\"un groupe de femmes\" />\n          </div>\n          <div className=\"content-metta\">\n            <h3> Quel est l'objectif ?</h3>\n            <p>\n              Ce programme est destiné à toutes les personnes qui souhaitent bouger leur corps et retrouver confiance en soi. Que ce soit pour <mark>te sentir à ta place, mieux te connaître ou réaliser des projets qui ont du sens pour toi.</mark> Si tu as l'impression que ça fait longtemps que tu stagnes, que tu ne te sens plus trop connecté.e à ton corps, que tu as perdu confiance en toi et que tu bloques.<strong>Ce suivi particulier mêlant yoga, son et accompagnement aide à retrouver une énergie qui te boost à fond !</strong>.</p><br />\n\n            <h3> Comment ça se déroule ?</h3>\n\n            <p> <strong>Sur une période de 4 mois</strong>, tu seras suivi.e individuellement avec des sessions collectives.\n              En fonction de tes besoins, tu auras accès à des sessions de yoga et d'accompagnement pédagogique. N'hésite pas à regarder les onglets dédiés sur ma page pour savoir ce que je propose ! Un point sera fait de façon régulière et tu auras accès à du contenu écrit pour t'aider à bénéficier des effets du programme dans ton quotidien.</p>\n            <li> Il y aura 12 ateliers répartis sur les 4 mois : cercle de parole sur une thématique, yoga, autres activités personnalisées 😃. </li>\n            <li> Un point individuel toutes les 2 semaines. </li>\n            <li> Un appel de groupe une fois par mois.</li>\n            <li> L'accès à une communauté pour vous apporter du soutien.</li>\n            <li>Un bilan à la fin du programme.</li> <br />\n\n\n            <h3> Est-ce fait pour toi ? </h3>\n            <p> Pas facile de trouver le temps et l'énergie d'avancer dans ses projets, d'y voir clair, de se sentir légitime et de questionner notre rapport au monde. <strong> Avoir un suivi permet de véritablement avancer sans se mettre de pression.</strong> Cela te permettra de te sentir moin seul.e, accompagné.e par une vision qui prend en compte l'impact des oppressions systémiques. J'ai une approche <mark><strong> déculpabilisante</strong> et tournée vers le monde qui t'entoure.</mark>\n              Si tu sens que tu as besoin <mark>qu'on te donne des objectifs</mark>, d'échanger, d'en apprendre plus sur les phénomènes systémiques et que tu es curieu.x.se d'explorer de nouveaux horizons alors ce programme est fait pour toi. Tu pourras de même rencontrer d'autres personnes partageant les même problématiques que toi et vous soutenir !\n            </p> <br />\n\n            <h3> Pour quel résultat ? </h3>\n            <p> À la fin <strong>tu auras les idées plus claires, des outils pour avancer dans des projets qui ont du sens, tu te sentiras plus connecté.e à ton corps et confiant.e.</strong> Tu repartiras boosté.e comme jamais. 🙌\n            </p> <br />\n\n            <blockquote><h5> Le programme n'est pas encore ouvert mais n'hésite pas à t'abonner à mon compte insta pour être au courant de la prochaine session 💫 </h5></blockquote>\n\n            <a href=\"\" style={{ marginBottom: 30 }} target=\"_blank\" rel=\"noopener\">\n              <button className=\"btn btn--follow\">\n                ▻▻ Me suivre pour en savoir plus\n              </button></a>\n          </div>\n        </div>\n      </div>\n      <Footer />\n    </div>\n  )\n}\n\nexport default Programme;\n","/Users/admin/code/Audrey-hello/web-site/src/pages/Coaching.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Voyage.js",["115"],"/* eslint-disable jsx-a11y/alt-text */\nimport React from 'react';\nimport ReactPlayer from 'react-player';\nimport '../styles/Voyage.css';\nimport voyage from '../img/voyage.png';\nimport Topbar from '../components/Topbar';\nimport Footer from '../components/Footer';\nimport GoToTop from '../components/GoToTop';\n\n\n\nexport default function Voyage() {\n  return (\n    <div className='voyage-container'>\n      <GoToTop />\n      <div className=\"voyage-banner\" >\n       <Topbar />\n        <ReactPlayer\n          url='voyage2.mp4'\n          className=\"video\"\n          width=\"100%\"\n          height=\"100%\"\n          object-fit=\"cover\"\n          muted={true}\n          playing={true}\n          loop={true}\n          controls={false}\n          allowfullscreen={true} />\n      </div>\n      <div className=\"content-tambour\">\n        <div>\n          <img className='image-profile-voyage' src={voyage} alt='moi avec un tambour' />\n        </div>\n\n        <div className='voyage-content'>\n          <h2>  La magie du son du tambour </h2> <br />\n\n         <p> Partir rencontrer son animal totem, échanger avec les esprits, trouver des messages, les vibrations du tambour t'emportera dans un univers magique. Issu des traditions chamaniques, le voyage au tambour nous permet de cheminer dans ce qui est appelé le \"monde invisible\". Les chamanes sont considéré.e.s comme étant des guériss.eurs.euses pouvant communiquer avec les esprits. On retrouve encore ces traditions chez certaines populations autochtones.</p>\n\n          <p> Depuis les recherches ont avancé, apportant plus d'explications sur ce qui se passe au niveau cérébral lorsqu'on effectue un voyage. Les vibrations émises par le tambour nous mènent à ce qu'on appelle un état modifié de conscience nous plongeant ainsi dans une sorte de rêve, voir de transe.</p>\n\n          <p> C'est une expérience qui reste unique pour chacun.e et les ressentis sont différents. On peut y trouver <strong>un état de relaxation, de réancrage, un travail sur le lâcher prise, des réponses à nos questions, une meilleure compréhension de nos états émotionnels</strong>...Vous venez y chercher ce que vous souhaitez ! </p>\n\n          <a href=\"\" target=\"_blank\" rel=\"noopener\"><button className=\"btn btn--follow\">\n            ▻▻ Suivre les prochaines sessions\n          </button></a>\n        </div>\n      </div>\n      <Footer />\n    </div>\n  );\n}\n","/Users/admin/code/Audrey-hello/web-site/src/pages/404_page.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Content.js",[],{"ruleId":"116","replacedBy":"117"},{"ruleId":"118","replacedBy":"119"},{"ruleId":"120","severity":1,"message":"121","line":45,"column":41,"nodeType":"122","messageId":"123","endLine":45,"endColumn":45},{"ruleId":"124","severity":1,"message":"125","line":20,"column":11,"nodeType":"126","endLine":20,"endColumn":22},{"ruleId":"124","severity":1,"message":"125","line":21,"column":11,"nodeType":"126","endLine":21,"endColumn":23},{"ruleId":"124","severity":1,"message":"125","line":23,"column":11,"nodeType":"126","endLine":23,"endColumn":23},{"ruleId":"124","severity":1,"message":"125","line":68,"column":15,"nodeType":"126","endLine":68,"endColumn":27},{"ruleId":"124","severity":1,"message":"125","line":69,"column":15,"nodeType":"126","endLine":69,"endColumn":27},{"ruleId":"124","severity":1,"message":"125","line":53,"column":11,"nodeType":"126","endLine":53,"endColumn":53},{"ruleId":"124","severity":1,"message":"125","line":69,"column":13,"nodeType":"126","endLine":69,"endColumn":84},{"ruleId":"124","severity":1,"message":"125","line":44,"column":11,"nodeType":"126","endLine":44,"endColumn":53},"no-native-reassign",["127"],"no-negated-in-lhs",["128"],"react/jsx-no-comment-textnodes","Comments inside children section of tag should be placed inside braces","Literal","putCommentInBraces","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-global-assign","no-unsafe-negation"]