ount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"88","messages":"89","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"90","messages":"91","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"92","messages":"93","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"94","messages":"95","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"96","usedDeprecatedRules":"54"},{"filePath":"97","messages":"98","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},{"filePath":"103","messages":"104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"105","messages":"106","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"54"},"/Users/admin/code/Audrey-hello/web-site/src/index.js",[],["107","108"],"/Users/admin/code/Audrey-hello/web-site/src/reportWebVitals.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/App.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Contact.js",["109"],"import React, { useState } from 'react';\nimport { useForm } from 'react-hook-form';\nimport './Contact.css';\nimport Topbar from './Topbar';\nimport Footer from './Footer';\nimport { init, sendForm } from 'emailjs-com';\ninit(\"user_Boc5zsTh76kXC3qdiR1Fa\");\n\n\n\nconst Contact = () => {\n\n\n  const { register, handleSubmit, watch, formState: { errors } } = useForm(\"\");\n  const onSubmit = data => {\n  console.log(data);\n\n  const statusMessage = document.querySelector('.status-message');\n  const form = document.querySelector('#contact-form');\n  generateContactNumber();\n  sendForm('default_service', 'template_32681fl', '#contact-form')\n    .then(function (response) {\n      console.log('SUCCESS!', response.status, response.text);\n      form.reset();\n      setStatusMessage(\"Message envoyé!\");\n      statusMessage.className = \"status-message success\";\n      setTimeout(() => {\n        statusMessage.className = 'status-message'\n      }, 5000)\n    }, function (error) {\n      console.log('FAILED...', error);\n      setStatusMessage(\"Le message n'est pas passé...retentez !\");\n      statusMessage.className = \"status-message failure\";\n      setTimeout(() => {\n        statusMessage.className = 'status-message'\n      }, 10000)\n    });\n}\n\n  const validator = require(\"email-validator\");\n  ;\n  const message = watch('message') || \"\";\n  const messageCharsLeft = 1500 - message.length;\n  const [contactNumber, setContactNumber] = useState(\"000000\");\n  const [statusMessage, setStatusMessage] = useState(\"Message\");\n  const generateContactNumber = () => {\n  const numStr = \"000000\" + (Math.random() * 1000000 | 0);\n  setContactNumber(numStr.substring(numStr.length - 6));\n}\n\n  return (\n    <>\n     <div className=\"entete\">\n       <Topbar />\n      </div>\n    <div className='contact'>\n      <strong><h1 className='title-contact'>Contact</h1></strong>\n       <p className='status-message'>{statusMessage}</p>\n      <div className=\"container-contact-form\">\n        <form id='contact-form' onSubmit={handleSubmit(onSubmit)}>\n          <input type='hidden' name='contact_number' value={contactNumber} />\n          {errors.user_name && errors.user_name.type === \"required\" && (\n            <div role=\"alert\">Name is required<br /></div>\n          )}\n          <p> Nom complet* </p>\n\n          <div className=\"nom_complet\">\n            <span className=\"container-prénom\">\n              <input\n              type='text'\n              className=\"input-prénom\"\n              name='user_firstname'\n              ref={register('')}\n              maxLength='30'\n              aria-invalid={errors.user_firstname ? \"true\" : \"false\"}\n              { ...register('user_firstname', { required: true } )}\n                  />\n              <label className=\"prénom\">  Prénom </label>\n            </span>\n            <span className=\"container-nom\">\n              <input\n                type='text'\n                className=\"input-nom\"\n                name='user_lastname'\n                ref={register('')}\n                maxLength='30'\n                aria-invalid={errors.user_lastname ? \"true\" : \"false\"}\n                {...register('user_lastname', { required: true })}\n                />\n              <label className=\"nom\"> Nom </label></span>\n          </div>\n          <br />\n          <div className=\"input-container\">\n            <p> Email* </p>\n            <input type='email' name='user_email' ref={register('a@gmail.com')} onChange={validator.validate(\"test@email.com\")}  />\n            <br />\n            <p className=\"label-message\"> Message* </p>\n          <div className=\"message-container\">\n            <textarea id=\"input-message\" name='message' ref={register('a@gmail.com')} maxLength='1500' />\n          </div>\n          <br />\n            <input type='submit' value='Envoyer' className=\"envoyer\" />\n          </div>\n        </form>\n      </div>\n      <Footer />\n    </div>\n  </>\n  );\n}\nexport default Contact;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/pages/Home.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Banner.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Profile.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Cards.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Footer.js",["110","111","112","113","114"],"/* eslint-disable jsx-a11y/alt-text */\nimport { Link } from 'react-router-dom';\nimport './Footer.css';\nimport instagram from './instagram.svg';\nimport facebook from './facebook.svg';\nimport mail from './mail.svg';\nimport pinterest from './pinterest.svg';\nimport tiktok from './tiktok.svg';\n\n\nfunction Footer() {\n  return (\n    <div className='footer-container'>\n      <div className=\"logo-footer\">\n        <h1 className=\"title-logo\">Résonance </h1>\n      </div>\n      <div className=\"footer-links\">\n        <h2 className=\"title-footer\"> Me suivre </h2>\n        <div className=\"social-media-footer\">\n          <a href=\"https://www.instagram.com/ana.resonance/\"><i><img src={instagram} className=\"social-logo\" alt=\"image du logo insta\" /></i></a>\n          <a href=\"https://vm.tiktok.com/ZMRMAQFm9/\" ><i><img src={tiktok} className=\"social-logo\" alt=\"image du logo tiktok\" /></i></a>\n          <a href=\"https://www.facebook.com/resonance.anahata\" ><i><img src={facebook} className=\"social-logo\" alt=\"image du logo facebook\" /></i></a>\n          <a href=\"https://www.pinterest.fr/anahataresonance/_created/\" ><i><img src={pinterest} className=\"social-logo-pint\" alt=\"image du logo facebook\" /></i></a>\n        </div>\n      </div>\n      <div className=\"contact-content\">\n        <div className=\"contacter\">\n          <h2 className=\"title-footer\" id='footer'>Me contacter</h2>\n          <div className=\"social-logo-mail\" >\n            <Link to={'/Contact'} >\n            <img src={mail} className=\"social-logo-mail\" alt=\"image du logo mail\" />\n            </Link>\n          </div>\n        </div>\n      </div>\n      <div className=\"mentions-légales\">\n        <h2 className=\"title-mention\" > Conditions générales du site </h2>\n        <div className=\"block-lien-mention\">\n          <a href=\"https://docs.google.com/document/d/1d9N3qxisZQ_xxm1bSfb7_k7EeZe5O4-B4vTLXVc2oCk/edit?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Mentions légales</a>\n          <a href=\"https://drive.google.com/file/d/148ZLMYZs71JNm87HV19-L-t_PTVNaJMc/view?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Politique de confidentialité\n          </a>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Banner2.js",["115"],"import React from 'react';\nimport './Banner.css';\n\nfunction Banner2() {\n  return (\n    <div className='banner-container2'>\n      <div className=\"image-banner2\" >\n        <img src=\"https://images.unsplash.com/photo-1517363898874-737b62a7db91?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1558&q=80\" alt=\"image unsplash d'une femme méditant\"/>\n      </div>\n    </div>\n  )\n};\n\nexport default Banner2;\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Button.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Yoga.js",["116"],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Voyage.js",["117"],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Coaching.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Events.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Topbar.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Content.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Profile2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/OnePost.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/AllPosts.js",["118"],"/* eslint-disable jsx-a11y/img-redundant-alt */\n// src/components/AllPosts.js\n\nimport React, { useEffect, useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport sanityClient from \"./Client.js\";\nimport Topbar from './Topbar';\nimport './Content.css';\nimport ressources2 from './ressources2.png';\nimport Footer from './Footer';\n\nexport default function AllPosts() {\n  const [allPostsData, setAllPosts] = useState(null);\n\n  useEffect(() => {\n    sanityClient\n      .fetch(\n        `*[_type == \"post\"]{\n        title,\n        slug,\n        mainImage{\n          asset->{\n          _id,\n          url\n        }\n      }\n    }`\n      )\n      .then((data) => setAllPosts(data))\n      .catch(console.error);\n  }, []);\n\n  return (\n    <>\n    <div className=\"events-container min-h-screen \" id=\"events\">\n          <div className='banner-container3'>\n            <div className=\"image-banner-content\" >\n              <Topbar />\n              <img src={ressources2} alt=\"Image de la bannière avec un café en fond pour la page blog\"/>\n            </div>\n          </div>\n        <div className=\"cards-content\">\n          <div className=\"text-metta\">\n            <div className=\"title-metta\">\n              <li> Bien-être </li><span> // </span><li> Empowerment </li>\n            </div>\n          </div>\n          <div className=\"content-metta\">\n            <div className=\"container-cards-blog\">\n\n          <div className=\"card-blog\">\n\n          {allPostsData &&\n            allPostsData.map((post, index) => (\n                <span\n                  className=\"block h-64 relative rounded shadow leading-snug bg-white\"\n                  key={index}\n                >\n\n                <Link to={\"/\" + post.slug.current } key={post.slug.current}>\n                  <img\n                    className=\"w-full h-full rounded-r object-cover absolute\"\n                    src={post.mainImage.asset.url}\n                    alt=\"Image des posts du blog pour mettre en avant les titres\"\n                  />\n                  </Link>\n                  <span\n                    className=\"block relative h-full flex justify-end items-end pr\n                      -4 pb-4\">\n                  </span>\n                <h1>\n                  {post.title}\n                </h1>\n               </span>\n            )) }\n         </div>\n        </div>\n        </div>\n        </div>\n        <Footer />\n      </div>\n    </>\n  );\n}\n","/Users/admin/code/Audrey-hello/web-site/src/components/components/Client.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/Popup.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/404_page.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/PreLoader.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/components/GoToTop.js",[],{"ruleId":"119","replacedBy":"120"},{"ruleId":"121","replacedBy":"122"},{"ruleId":"123","severity":1,"message":"124","line":43,"column":9,"nodeType":"125","messageId":"126","endLine":43,"endColumn":25},{"ruleId":"127","severity":1,"message":"128","line":20,"column":65,"nodeType":"129","endLine":20,"endColumn":138},{"ruleId":"127","severity":1,"message":"128","line":21,"column":58,"nodeType":"129","endLine":21,"endColumn":129},{"ruleId":"127","severity":1,"message":"128","line":22,"column":68,"nodeType":"129","endLine":22,"endColumn":143},{"ruleId":"127","severity":1,"message":"128","line":23,"column":77,"nodeType":"129","endLine":23,"endColumn":158},{"ruleId":"127","severity":1,"message":"128","line":31,"column":13,"nodeType":"129","endLine":31,"endColumn":85},{"ruleId":"127","severity":1,"message":"128","line":8,"column":9,"nodeType":"129","endLine":8,"endColumn":222},{"ruleId":"130","severity":1,"message":"131","line":54,"column":11,"nodeType":"129","messageId":"132","endLine":54,"endColumn":93,"fix":"133"},{"ruleId":"130","severity":1,"message":"131","line":44,"column":11,"nodeType":"129","messageId":"132","endLine":44,"endColumn":93,"fix":"134"},{"ruleId":"135","severity":1,"message":"136","line":45,"column":41,"nodeType":"137","messageId":"138","endLine":45,"endColumn":45},"no-native-reassign",["139"],"no-negated-in-lhs",["140"],"no-unused-vars","'messageCharsLeft' is assigned a value but never used.","Identifier","unusedVar","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","JSXOpeningElement","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","noTargetBlank",{"range":"141","text":"142"},{"range":"143","text":"142"},"react/jsx-no-comment-textnodes","Comments inside children section of tag should be placed inside braces","Literal","putCommentInBraces","no-global-assign","no-unsafe-negation",[2883,2893],"\"noopener noreferrer\"",[2195,2205]]