Count":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"62","messages":"63","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"68","usedDeprecatedRules":"52"},{"filePath":"69","messages":"70","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"71","messages":"72","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"73","messages":"74","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"75","messages":"76","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"77","messages":"78","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"79","messages":"80","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"81","messages":"82","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"83","messages":"84","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"85","messages":"86","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"87","messages":"88","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"89","messages":"90","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"91","messages":"92","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"95","messages":"96","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"97","messages":"98","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"52"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/admin/code/Audrey-hello/web-site/src/index.js",[],["101","102"],"/Users/admin/code/Audrey-hello/web-site/src/reportWebVitals.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/App.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/AllPosts.js",["103"],"/* eslint-disable jsx-a11y/img-redundant-alt */\n// src/components/AllPosts.js\n\nimport React, { useEffect, useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport sanityClient from \"./Client.js\";\nimport Topbar from './Topbar';\nimport '../styles/Content.css';\nimport ressources2 from '../img/ressources2.png';\nimport Footer from './Footer';\n\nexport default function AllPosts() {\n  const [allPostsData, setAllPosts] = useState(null);\n\n  useEffect(() => {\n    sanityClient\n      .fetch(\n        `*[_type == \"post\"]{\n        title,\n        slug,\n        mainImage{\n          asset->{\n          _id,\n          url\n        }\n      }\n    }`\n      )\n      .then((data) => setAllPosts(data))\n      .catch(console.error);\n  }, []);\n\n  return (\n    <>\n    <div className=\"events-container min-h-screen \" id=\"events\">\n          <div className='banner-container3'>\n            <div className=\"image-banner-content\" >\n              <Topbar />\n              <img src={ressources2} alt=\"Image de la bannière avec un café en fond pour la page blog\"/>\n            </div>\n          </div>\n        <div className=\"cards-content\">\n          <div className=\"text-metta\">\n            <div className=\"title-metta\">\n              <li> Bien-être </li><span> // </span><li> Empowerment </li>\n            </div>\n          </div>\n          <div className=\"content-metta\">\n            <div className=\"container-cards-blog\">\n\n          <div className=\"card-blog\">\n\n          {allPostsData &&\n            allPostsData.map((post, index) => (\n                <span\n                  className=\"block h-64 relative rounded shadow leading-snug bg-white\"\n                  key={index}\n                >\n\n                <Link to={\"/\" + post.slug.current } key={post.slug.current}>\n                  <img\n                    className=\"w-full h-full rounded-r object-cover absolute\"\n                    src={post.mainImage.asset.url}\n                    alt=\"Image des posts du blog pour mettre en avant les titres\"\n                  />\n                  </Link>\n                  <span\n                    className=\"block relative h-full flex justify-end items-end pr\n                      -4 pb-4\">\n                  </span>\n                <h1>\n                  {post.title}\n                </h1>\n               </span>\n            )) }\n         </div>\n        </div>\n        </div>\n        </div>\n        <Footer />\n      </div>\n    </>\n  );\n}\n","/Users/admin/code/Audrey-hello/web-site/src/components/OnePost.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Profile2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Client.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Footer.js",["104","105","106"],"/* eslint-disable jsx-a11y/alt-text */\nimport { Link } from 'react-router-dom';\nimport '../styles/Footer.css';\nimport instagram from '../img/instagram.svg';\nimport facebook from '../img/facebook.svg';\nimport mail from '../img/mail.svg';\nimport pinterest from '../img/pinterest.svg';\nimport tiktok from '../img/tiktok.svg';\n\n\nfunction Footer() {\n  return (\n    <div className='footer-container'>\n      <div className=\"logo-footer\">\n        <h1 className=\"title-logo\">Résonance </h1>\n      </div>\n      <div className=\"footer-links\">\n        <h2 className=\"title-footer\"> Me suivre </h2>\n        <div className=\"social-media-footer\">\n          <a href=\"\"><i><img src={instagram} className=\"social-logo\" alt=\"logo insta\" /></i></a>\n          <a href=\"\" ><i><img src={tiktok} className=\"social-logo\" alt=\"logo tiktok\" /></i></a>\n          <a href=\"https://www.facebook.com/resonance.anahata\" ><i><img src={facebook} className=\"social-logo\" alt=\"logo facebook\" /></i></a>\n          <a href=\"\" ><i><img src={pinterest} className=\"social-logo-pint\" alt=\"logo facebook\" /></i></a>\n        </div>\n      </div>\n      <div className=\"contact-content\">\n        <div className=\"contacter\">\n          <h2 className=\"title-footer\" id='footer'>Me contacter</h2>\n          <div className=\"social-logo-mail\" >\n            <Link to={'/Contact'} >\n            <img src={mail} className=\"social-logo-mail\" alt=\"logo mail\" />\n            </Link>\n          </div>\n        </div>\n      </div>\n      <div className=\"mentions-légales\">\n        <h2 className=\"title-mention\" > Conditions générales du site </h2>\n        <div className=\"block-lien-mention\">\n          <a href=\"https://docs.google.com/document/d/1d9N3qxisZQ_xxm1bSfb7_k7EeZe5O4-B4vTLXVc2oCk/edit?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Mentions légales</a>\n          <a href=\"https://drive.google.com/file/d/148ZLMYZs71JNm87HV19-L-t_PTVNaJMc/view?usp=sharing\"\n            target=\"_blank\"\n            rel=\"noreferrer\"\n            className=\"lien-mention\"> Politique de confidentialité\n          </a>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n","/Users/admin/code/Audrey-hello/web-site/src/components/Topbar.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Popup.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Button.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/GoToTop.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Cards.js",["107","108"],"/Users/admin/code/Audrey-hello/web-site/src/components/Banner2.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Profile.js",[],"/Users/admin/code/Audrey-hello/web-site/src/components/Banner.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Home.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Yoga.js",["109"],"/Users/admin/code/Audrey-hello/web-site/src/pages/Contact.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Programme.js",["110"],"/Users/admin/code/Audrey-hello/web-site/src/pages/Coaching.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Voyage.js",["111"],"/Users/admin/code/Audrey-hello/web-site/src/pages/404_page.js",[],"/Users/admin/code/Audrey-hello/web-site/src/pages/Content.js",[],{"ruleId":"112","replacedBy":"113"},{"ruleId":"114","replacedBy":"115"},{"ruleId":"116","severity":1,"message":"117","line":45,"column":41,"nodeType":"118","messageId":"119","endLine":45,"endColumn":45},{"ruleId":"120","severity":1,"message":"121","line":20,"column":11,"nodeType":"122","endLine":20,"endColumn":22},{"ruleId":"120","severity":1,"message":"121","line":21,"column":11,"nodeType":"122","endLine":21,"endColumn":23},{"ruleId":"120","severity":1,"message":"121","line":23,"column":11,"nodeType":"122","endLine":23,"endColumn":23},{"ruleId":"120","severity":1,"message":"121","line":68,"column":15,"nodeType":"122","endLine":68,"endColumn":27},{"ruleId":"120","severity":1,"message":"121","line":69,"column":15,"nodeType":"122","endLine":69,"endColumn":27},{"ruleId":"120","severity":1,"message":"121","line":53,"column":11,"nodeType":"122","endLine":53,"endColumn":53},{"ruleId":"120","severity":1,"message":"121","line":69,"column":13,